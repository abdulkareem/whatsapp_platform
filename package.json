{
  "name": "whatsapp-platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "dev:backend": "npm run dev -w @whatsapp-platform/backend",
    "dev": "echo 'Run dev:backend and dev:frontend in separate terminals'",
    "dev:frontend": "npm run dev -w @whatsapp-platform/frontend"
  }
}
