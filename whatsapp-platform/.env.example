PORT=8080
NODE_ENV=development
WEBHOOK_VERIFY_TOKEN=your_verify_token
META_APP_SECRET=your_meta_app_secret
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
PHONE_NUMBER_ID=your_phone_number_id
MYCROWB_API_URL=https://mycrowb.app/api/whatsapp-incoming
MYCROWB_API_KEY=your_mycrowb_api_key
# Optional JSON array for routing rules. Example:
# CLIENT_ROUTE_CONFIG=[{"name":"MYCROWB","endpoint":"https://mycrowb.app/api/whatsapp-incoming","apiKey":"abc","keywords":["otp"],"phonePrefixes":["234"]}]
CLIENT_ROUTE_CONFIG=[]
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
WHATSAPP_API_TIMEOUT_MS=10000
CLIENT_FORWARD_TIMEOUT_MS=10000
