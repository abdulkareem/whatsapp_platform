{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build -w @whatsapp-platform/backend"
  },
  "deploy": {
    "startCommand": "npm run start -w @whatsapp-platform/backend",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
