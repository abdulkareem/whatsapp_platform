generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model App {
  id            Int           @id @default(autoincrement())
  name          String
  keyword       String        @unique
  endpoint      String
  apiKey        String        @unique
  rateLimitRpm  Int           @default(100)
  isActive      Boolean       @default(true)
  sessionEnabled Boolean      @default(true)
  sessionTimeoutMinutes Int   @default(15)
  keywordRequired Boolean     @default(true)
  defaultApp    Boolean       @default(false)
  fallbackMessage String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  conversations Conversation[]
}

model MessageLog {
  id               Int       @id @default(autoincrement())
  mobile           String
  message          String
  direction        String
  app              String
  status           String    @default("queued")
  providerMessageId String?
  createdAt        DateTime  @default(now())
}

model Otp {
  id        Int      @id @default(autoincrement())
  mobile    String
  code      String
  app       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("OTP")
}

model Conversation {
  id         Int      @id @default(autoincrement())
  mobile     String
  appId      Int
  lastMessage String
  sessionExpiresAt DateTime?
  updatedAt  DateTime @updatedAt
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([mobile, appId])
}


model AdminOtp {
  id        Int      @id @default(autoincrement())
  mobile    String
  deviceId  String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile, deviceId, code, used])
}

model AdminDevicePin {
  id             Int      @id @default(autoincrement())
  mobile         String
  deviceId       String
  pin            String
  whatsappLinked Boolean  @default(false)
  lastVerifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([mobile, deviceId])
}
